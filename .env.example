# Copy this file to `.env` for local development.
# Never commit real secrets in `.env`.

# ------------------------------------------------------------
# Local server
# ------------------------------------------------------------
PORT=3000
NODE_ENV=development

# Optional: when DATABASE_URL is empty, the app uses this JSON file for local data.
# Delete the file to reset local test data.
LOCAL_DATA_PATH=.local-data/senior-store.json

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Optional for local UI testing. Required for real/stable deployment.
# Example: mysql://user:password@host:3306/database
DATABASE_URL=

# ------------------------------------------------------------
# Auth / Manus runtime
# ------------------------------------------------------------
# Optional for local UI-only testing. Required when using real Manus OAuth.
JWT_SECRET=replace-with-a-long-random-string
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# Manus built-in APIs. Usually provided by Manus hosting/runtime.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional analytics placeholders used by index.html.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ------------------------------------------------------------
# Gemini
# ------------------------------------------------------------
# Required for AI greeting/care advice generation.
VITE_GEMINI_API_KEY=

# ------------------------------------------------------------
# LINE Messaging API
# ------------------------------------------------------------
# Required for real Line push messages and webhook signature verification.
LINE_CHANNEL_ID=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Public URL used inside Line quick-reply/report links.
# In local testing, this can be http://localhost:3000.
# In production, use the deployed HTTPS origin.
APP_BASE_URL=http://localhost:3000

# ------------------------------------------------------------
# Daily greeting scheduler
# ------------------------------------------------------------
# Set false while developing if you do not want any scheduled Line sends.
DAILY_GREETING_ENABLED=false

# Default is 8, interpreted in DAILY_GREETING_TIME_ZONE.
DAILY_GREETING_HOUR=8
DAILY_GREETING_TIME_ZONE=Asia/Taipei
